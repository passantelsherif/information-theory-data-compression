from PIL import Image
import numpy as np
import os
import pickle

def create_quantizer(target_bits=2, full_scale=256):
    step = full_scale / (2 ** target_bits)
    
    midpoints = []
    quantizer_table = []
    num_levels = 2 ** target_bits
    
    # Calculate ranges centered around 0
    range_half = full_scale / 2
    
    for i in range(num_levels):
        # Interval range
        start = -range_half + i * step
        end = -range_half + (i + 1) * step
        
        # Dequantization value (midpoint)
        midpoint = (start + end) / 2
        midpoints.append(midpoint)
        
        # Store quantizer table
        quantizer_table.append({
            'binary_code': i,
            'interval_start': start,
            'interval_end': end,
            'dequant_value': midpoint
        })
    
    return midpoints, step, quantizer_table

def quantize_value(value, midpoints, step, range_half, target_bits):
    shifted = value + range_half
    if shifted < 0:
        code = 0
    elif shifted >= step * (2**target_bits):
        code = (2**target_bits) - 1
    else:
        code = int(shifted // step)
    
    return code, midpoints[code]

def compress_image(image_path, target_bits):
    # Load image
    img = Image.open(image_path).convert('L')
    original = np.array(img, dtype=np.int32)
    h, w = original.shape
    
    # Create quantizer
    midpoints, step, quantizer_table = create_quantizer(target_bits)
    range_half = 256 / 2
    
    # Arrays for all required images
    predicted = np.zeros_like(original, dtype=np.int32)
    error = np.zeros_like(original, dtype=np.float32)
    quantized = np.zeros_like(original, dtype=np.int32)
    dequantized = np.zeros_like(original, dtype=np.float32)
    decoded = np.zeros_like(original, dtype=np.int32)
    
    # Store first row and first column from original
    first_row = original[0, :].copy()
    first_col = original[:, 0].copy()
    
    # Copy first row and column to decoded image (no prediction needed for these)
    decoded[0, :] = first_row
    decoded[:, 0] = first_col
    
    # For first row and column, prediction is 0 (we just copy original)
    predicted[0, :] = 0
    predicted[:, 0] = 0
    error[0, :] = 0
    error[:, 0] = 0
    quantized[0, :] = 0
    quantized[:, 0] = 0
    dequantized[0, :] = 0
    dequantized[:, 0] = 0
    
    # Process only interior pixels (starting from i=1, j=1)
    for i in range(1, h):
        for j in range(1, w):
            # Use adaptive predictor on decoded values
            A = decoded[i, j-1]    # Left (already decoded)
            B = decoded[i-1, j-1]  # Top-left (already decoded)
            C = decoded[i-1, j]    # Top (already decoded)
            
            if B <= min(A, C):
                pred_val = min(A, C)
            elif B >= max(A, C):
                pred_val = max(A, C)
            else:
                pred_val = A + C - B
            
            predicted[i, j] = pred_val
            
            # Calculate error
            current_error = original[i, j] - pred_val
            error[i, j] = current_error
            
            # Quantize error
            code, dequant_val = quantize_value(current_error, midpoints, step, range_half, target_bits)
            quantized[i, j] = code
            dequantized[i, j] = dequant_val
            
            # Decode (reconstruct) value
            decoded[i, j] = pred_val + dequant_val
    
    # Clip decoded values
    decoded = np.clip(decoded, 0, 255).astype(np.uint8)
    original_uint8 = original.astype(np.uint8)
    
    # Print only essential info
    print(f"\nQuantizer Table ({target_bits} bits):")
    print(f"{'Code':<6} {'Start':<10} {'End':<10} {'Dequant':<10}")
    print("-" * 40)
    for entry in quantizer_table:
        print(f"{entry['binary_code']:<6} {entry['interval_start']:<10.1f} {entry['interval_end']:<10.1f} {entry['dequant_value']:<10.1f}")
    
    # Compression ratio
    original_bits = h * w * 8
    compressed_bits = ((w + h - 1) * 8) + ((h - 1) * (w - 1) * target_bits)
    ratio = original_bits / compressed_bits
    
    print(f"\nCompression Ratio: {ratio:.2f}:1")
    
    # Save all 6 images
    base_name = os.path.splitext(os.path.basename(image_path))[0]
    
    # 1. Original
    Image.fromarray(original_uint8).save(f"{base_name}_original.png")
    
    # 2. Predicted
    predicted_vis = np.clip(predicted, 0, 255).astype(np.uint8)
    Image.fromarray(predicted_vis).save(f"{base_name}_predicted.png")
    
    # 3. Error
    error_vis = (error + 128).clip(0, 255).astype(np.uint8)
    Image.fromarray(error_vis).save(f"{base_name}_error.png")
    
    # 4. Quantized
    if target_bits > 0:
        scale = 255 // ((2**target_bits) - 1)
        quantized_vis = (quantized * scale).astype(np.uint8)
    else:
        quantized_vis = quantized.astype(np.uint8)
    Image.fromarray(quantized_vis).save(f"{base_name}_quantized.png")
    
    # 5. Dequantized
    dequantized_vis = (dequantized + 128).clip(0, 255).astype(np.uint8)
    Image.fromarray(dequantized_vis).save(f"{base_name}_dequantized.png")
    
    # 6. Decoded
    Image.fromarray(decoded).save(f"{base_name}_decoded.png")
    
    print(f"\nImages saved with prefix: {base_name}_")
    
    # Save compressed data (pickle file)
    compressed_data = {
        'quantized': quantized,
        'first_row': first_row.tolist(),
        'first_col': first_col.tolist(),
        'height': h,
        'width': w,
        'target_bits': target_bits,
        'compression_ratio': ratio
    }
    
    compressed_filename = f"{base_name}_{target_bits}bit.pkl"
    with open(compressed_filename, 'wb') as f:
        pickle.dump(compressed_data, f)
    
    print(f"Compressed data saved: {compressed_filename}")
    
    return compressed_filename

def decompress_image(compressed_path):
    # Load compressed data
    with open(compressed_path, 'rb') as f:
        compressed_data = pickle.load(f)
    
    quantized = np.array(compressed_data['quantized'])
    first_row = np.array(compressed_data['first_row'])
    first_col = np.array(compressed_data['first_col'])
    h = compressed_data['height']
    w = compressed_data['width']
    target_bits = compressed_data['target_bits']
    
    print(f"\nDecompressing: {w}x{h} image, {target_bits}-bit quantization")
    
    # Create quantizer
    midpoints, step, quantizer_table = create_quantizer(target_bits)
    
    # Initialize decoded image
    decoded = np.zeros((h, w), dtype=np.int32)
    
    # Set first row and first column from stored data
    decoded[0, :] = first_row
    decoded[:, 0] = first_col
    
    # Process only interior pixels (starting from i=1, j=1)
    for i in range(1, h):
        for j in range(1, w):
            # Get neighbors
            A = decoded[i, j-1]
            B = decoded[i-1, j-1]
            C = decoded[i-1, j]
            
            # Adaptive predictor
            if B <= min(A, C):
                pred_val = min(A, C)
            elif B >= max(A, C):
                pred_val = max(A, C)
            else:
                pred_val = A + C - B
            
            # Get dequantized error
            dequant_val = midpoints[quantized[i, j]]
            
            # Reconstruct pixel
            decoded[i, j] = pred_val + dequant_val
    
    # Clip and convert
    decoded = np.clip(decoded, 0, 255).astype(np.uint8)
    
    # Save decompressed image
    base_name = os.path.splitext(compressed_path)[0]
    decompressed_filename = f"{base_name}_decompressed.png"
    Image.fromarray(decoded).save(decompressed_filename)
    
    print(f"Decompressed image saved: {decompressed_filename}")
    
    return decoded

def main():
    while True:
        print("\n" + "="*60)
        print("FEED BACKWARD DPCM - 2D ADAPTIVE PREDICTIVE CODING")
        print("="*60)
        print("1. Compress Image (Feed Backward)")
        print("2. Decompress Image (Feed Backward)")
        print("3. Exit")
        print("="*60)
        
        choice = input("Choice (1-3): ").strip()
        
        if choice == "1":
            # Get image path
            path = input("Image path: ").strip('"')
            if not os.path.exists(path):
                print("File not found!")
                continue
            
            # Get bits (any positive integer)
            while True:
                bits_input = input("Quantizer bits (positive integer, default=2): ").strip()
                if bits_input == "":
                    target_bits = 2
                    break
                try:
                    target_bits = int(bits_input)
                    if target_bits > 0:
                        break
                    print("Please enter a positive integer.")
                except:
                    print("Please enter a valid integer.")
            
            try:
                compressed_file = compress_image(path, target_bits)
                
                print(f"\nCompression complete!")
                print(f"Pickle file: {compressed_file}")
                print(f"6 images saved with prefix: {os.path.splitext(os.path.basename(path))[0]}_")
                
            except Exception as e:
                print(f"\nError during compression: {str(e)}")
        
        elif choice == "2":
            path = input("Compressed file path (.pkl): ").strip('"')
            
            if not os.path.exists(path):
                print("File not found!")
                continue
            
            if not path.endswith('.pkl'):
                print("Please provide a .pkl file")
                continue
            
            try:
                decoded = decompress_image(path)
                print("\nDecompression complete!")
                
            except Exception as e:
                print(f"\nError during decompression: {str(e)}")
        
        elif choice == "3":
            print("Goodbye!")
            break
        
        else:
            print("Invalid choice!")

if __name__ == "__main__":
    main()
